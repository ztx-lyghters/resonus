<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="expo.modules.carauto" >

    <uses-sdk android:minSdkVersion="24" />
    <!--
       Permite instalar en Android Automotive OS sin exigir hardware de coche
       (así también funciona como app de proyección Android Auto en el móvil).
    -->
    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="false" />

    <application>

        <!-- Declara la app como app de medios para Android Auto (proyección). -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <service
            android:name="expo.modules.carauto.ResonusCarBrowserService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback" >
            <intent-filter>
                <action android:name="androidx.media3.session.MediaLibraryService" />
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>
    </application>

</manifest>