<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- Servicio foreground que mantiene viva la sesión de medios (controles de
       bloqueo + botones de volumen) mientras se castea por UPnP. Los permisos
       FOREGROUND_SERVICE(_MEDIA_PLAYBACK) ya los declara la app. -->
  <application>
    <service
      android:name="expo.modules.castmedia.CastMediaService"
      android:exported="false"
      android:foregroundServiceType="mediaPlayback" />
  </application>
</manifest>
